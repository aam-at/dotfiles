alias -- -="cd -"

# Add an "alert" alias for long running commands.  Use like so:
#   sleep 10; alert
alias alert='notify-send --urgency=low -i "$([ $? = 0 ] && echo terminal || echo error)" "$(history|tail -n1|sed -e '\''s/^\s*[0-9]\+\s*//;s/[;&|]\s*alert$//'\'')"'

# copy alias
function copy() {
  if command -v wl-copy >/dev/null 2>&1; then
    wl-copy "$@"
  elif command -v xclip >/dev/null 2>&1; then
    xclip -selection clipboard "$@"
  elif command -v xsel >/dev/null 2>&1; then
    xsel --clipboard --input "$@"
  else
    echo "No clipboard utility found" >&2
  fi
}

# yazi alias
function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	yazi "$@" --cwd-file="$tmp"
	if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
		builtin cd -- "$cwd"
	fi
	rm -f -- "$tmp"
}

# Unified search function - search with ripgrep and fzf preview
search() {
    if [ $# -eq 0 ]; then
        echo "Usage: search <pattern> [path]"
        echo "Search for pattern using ripgrep with fzf preview"
        return 1
    fi
    local pattern="$1"
    shift
    local path="${1:-.}"
    rg --hidden --glob '!.git' --color=always "$pattern" "$path" | \
        fzf --ansi --preview 'bat --style=numbers --color=always --highlight-line {2} {1}' \
            --preview-window 'right:60%' \
            --bind 'enter:become(nvim {1} +{2})'
}

# Quick file search with fd and fzf
fs() {
    local file
    file=$(fd --type f --color=always | fzf --ansi --preview 'bat --style=numbers --color=always {}' --preview-window 'right:60%')
    if [ -n "$file" ]; then
        nvim "$file"
    fi
}

# Directory search with fd and fzf
ds() {
    local dir
    dir=$(fd --type d --color=always | fzf --ansi --preview 'tree -L 2 -C {}' --preview-window 'right:60%')
    if [ -n "$dir" ]; then
        cd "$dir" || return
    fi
}

# ruff alias
function ruff_format() {
    local file_to_format=$1

    # Sort imports and fix issues
    ruff check --select I --fix $file_to_format

    # Format the file
    ruff format $file_to_format
}

# aichat alias
function aichat() {
    local DEEPSEEK_API_KEY=$(copy_password.sh deepseek)
    local GEMINI_API_KEY=$(copy_password.sh gemini)
    env DEEPSEEK_API_KEY="$DEEPSEEK_API_KEY" GEMINI_API_KEY="$GEMINI_API_KEY" aichat "$@"
}

# If inside a kitty terminal, add aliases for kitty's icat, ssh, diff, and hg
if [[ -n $KITTY_PID ]]; then
  alias icat="kitten icat"
  alias ssh="kitty +kitten ssh"
  alias realssh="/usr/bin/ssh"
  alias diff="kitten diff"
  alias hg="kitten hyperlinked-grep"
fi
